<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:IMoRS.ViewModels"
        xmlns:avalonia="clr-namespace:Mapsui.UI.Avalonia;assembly=Mapsui.UI.Avalonia"
        xmlns:converters="using:IMoRS.Converters"


        x:Class="IMoRS.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/IMoRS.ico"
        Title="IMoRS"
        Width="1600"
        Height="900"
        CanResize="False"
        WindowDecorations="None"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="50">
    

    <!-- Анимации перехода для окна -->
    <Window.Transitions>
        <Transitions>
            <DoubleTransition Property="Width"
                              Duration="0:0:0.3" />
        </Transitions>
    </Window.Transitions>

    <!-- Контекст данных для дизайнера -->
    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <!-- Ресурсы окна -->
    <Window.Resources>
        <converters:BoolToBrushConverter x:Key="BoolToBrushConverter" />
    </Window.Resources>

    <!--Подключил стили-->
    <Window.Styles>
        <StyleInclude Source="/Styles/MainStyles.axaml" />
    </Window.Styles>

    <!-- Основной контейнер окна -->
    <Grid>
        
        
        
        <!--Фон-->
        <Image Source="/Assets/BackGroung.png"
               Stretch="UniformToFill" />

        <!--Затемнение-->
        <Border Classes="Overlay" />

        <!-- Основная сетка с отступами и анимацией прозрачности -->
        <Grid RowDefinitions="Auto *"
              Margin="15"
              RowSpacing="15"
              Opacity="{Binding AppOpacity}">

            <Grid.Transitions>
                <Transitions>
                    <DoubleTransition Property="Opacity"
                                      Duration="0:0:1" />
                </Transitions>
            </Grid.Transitions>

            <!--Верхняя панелька-->
            <Border Classes="Tile"
                    ClipToBounds="True"
                    PointerPressed="DragWindow">

                <Grid Grid.Row="0"
                      ColumnDefinitions="Auto *">

                    <!--Иконка приложения и название-->
                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">

                        <Image Source="/Assets/IMoRS.ico"
                               Width="50"
                               Height="50" />

                        <TextBlock Text="IMoRS"
                                   VerticalAlignment="Center"
                                   FontSize="25"
                                   Foreground="White"
                                   FontFamily="Cooper" />

                    </StackPanel>

                    <!--Кнопки управления окном-->
                    <Border Grid.Column="1"
                            Classes="TopTile">

                        <Grid ColumnDefinitions="Auto Auto Auto">

                            <!-- Кнопка свернуть -->
                            <Button Grid.Column="0"
                                    Classes="ButtonTop"
                                    CornerRadius="5, 0,0, 5"
                                    Command="{Binding Minimize}">

                                <Image Source="/Assets/minus.png"
                                       Classes="ButtonImage" />

                            </Button>

                            <!-- Кнопка развернуть/восстановить -->
                            <Button Grid.Column="1"
                                    Classes="ButtonTop"
                                    CornerRadius="0"
                                    Command="{Binding MaxRestore}">

                                <Grid>

                                    <Image Source="/Assets/square.png"
                                           Classes="ButtonImage"
                                           IsVisible="{Binding !IsMaximized}" />

                                    <Image Source="/Assets/doublesquare.png"
                                           Classes="ButtonImage"
                                           IsVisible="{Binding IsMaximized}" />

                                </Grid>

                            </Button>

                            <!-- Кнопка закрыть -->
                            <Button Grid.Column="2"
                                    Classes="CloseButton"
                                    Command="{Binding Close}">

                                <Image Source="/Assets/cross.png"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Width="20"
                                       Height="20" />

                            </Button>

                        </Grid>

                    </Border>

                </Grid>

            </Border>

            <!--Основная часть-->
            <Grid Grid.Row="1"
                  ColumnSpacing="10"
                  ColumnDefinitions="Auto *">

                <!--Openable Border - левая панель с информацией о метке -->
                <Border Grid.Column="0"
                        Classes="Tile"
                        Padding="10"
                        Width="{Binding PanelWidth1}"
                        HorizontalAlignment="Left">

                    <Border.Transitions>
                        <Transitions>
                            <DoubleTransition Property="Width"
                                              Duration="0:0:0.3" />
                        </Transitions>
                    </Border.Transitions>

                    <Grid RowSpacing="10">

                        <Grid.RowDefinitions>

                            <RowDefinition Height="380" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />

                        </Grid.RowDefinitions>

                        <!--Image Border - контейнер для изображения метки -->
                        <Border Grid.Row="0"
                                Classes="Tile">

                            <Grid HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Opacity="{Binding DescOpacity}">

                                <Grid.Transitions>
                                    <Transitions>
                                        <DoubleTransition Property="Opacity"
                                                          Duration="0:0:0.5" />
                                    </Transitions>
                                </Grid.Transitions>

                                <!-- Изображение метки -->
                                <Image Source="{Binding UserImage}"
                                       Stretch="Uniform"
                                       Margin="10" />

                                <!-- Кнопка редактирования изображения (появляется в режиме редактирования) -->
                                <Button IsVisible="{Binding IsEditing}"
                                        Opacity="{Binding EditPartsOpacity}"
                                        Classes="SideButton EditIconButton"
                                        Command="{Binding OpenListCommand}">

                                    <Border Classes="Tile">

                                        <Image Source="/Assets/editIcon.png"
                                               Margin="25" />

                                    </Border>

                                </Button>

                            </Grid>

                        </Border>

                        <!-- Панель настройки масштаба меток (появляется в режиме редактирования) -->
                        <Border Grid.Row="1"
                                Classes="Tile"
                                Padding="10"
                                IsVisible="{Binding IsEditing}">

                            <Grid RowDefinitions="Auto Auto *" 
                                  VerticalAlignment="Stretch"
                                  Height="{Binding SliderHeight}">

                                <Grid.Transitions>
                                    <Transitions>
                                        <DoubleTransition Property="Height"
                                                          Duration="0:0:0.3" />
                                    </Transitions>
                                </Grid.Transitions>

                                <!-- Заголовок слайдера -->
                                <TextBlock Grid.Row="0" 
                                           Text="Размер меток" 
                                           Foreground="White" 
                                           FontWeight="Bold" />

                                <!-- Текущее значение масштаба -->
                                <TextBlock Grid.Row="1" 
                                           Text="{Binding MarkerScale, StringFormat='Масштаб: {00:F2}'}"
                                           Foreground="White" />

                                <!-- Слайдер изменения масштаба меток -->
                                <Slider Grid.Row="2" 
                                        Classes="Neon"
                                        Minimum="0.05" 
                                        Maximum="1.0"
                                        Value="{Binding MarkerScale, Mode=TwoWay}"
                                        SmallChange="0.01" 
                                        LargeChange="0.1"
                                        VerticalAlignment="Top"
                                        TickFrequency="0.05" 
                                        IsSnapToTickEnabled="True" />

                            </Grid>

                        </Border>

                        <!--Description Border - блок с описанием метки -->
                        <Border Grid.Row="2"
                                Classes="Tile"
                                Padding="10">
                            
                            <Grid RowDefinitions="* Auto"
                                  Opacity="{Binding DescOpacity}">

                                <Grid.Transitions>
                                    <Transitions>
                                        <DoubleTransition Property="Opacity"
                                                          Duration="0:0:0.5" />
                                    </Transitions>
                                </Grid.Transitions>

                                <!-- Отображение описания (режим просмотра) -->
                                <Border Grid.Row="0"
                                        CornerRadius="10"
                                        ClipToBounds="True">

                                    <TextBlock Text="{Binding Description}"
                                               Classes="DescBlock"
                                               HorizontalAlignment="Stretch"
                                               VerticalAlignment="Stretch" />

                                </Border>

                                <!-- Поле редактирования описания (режим редактирования) -->
                                <TextBox Grid.Row="0"
                                         Classes="DescBox"
                                         Text="{Binding Description}"
                                         IsVisible="{Binding IsEditing}" />

                                <!-- Панель кнопок управления меткой -->
                                <Grid Grid.Row="1"
                                      ColumnDefinitions="* Auto * "
                                      HorizontalAlignment="Stretch">

                                    <!-- Кнопка удаления метки -->
                                    <Button Grid.Column="0"
                                            Classes="ControlButton SideButton GradientButton"
                                            Command="{Binding DeleteMarkerCommand}"
                                            HorizontalAlignment="Left">

                                        <StackPanel Classes="StackButtonControl">

                                            <Image Source="/Assets/minus.png"
                                                   Height="20"
                                                   Width="20" />

                                            <TextBlock Text="Удалить"
                                                       Foreground="White"
                                                       FontWeight="Bold"
                                                       FontSize="12" />

                                        </StackPanel>

                                    </Button>

                                    <!-- Контейнер для переключения между кнопками "Изменить" и "Применить" -->
                                    <Grid Grid.Column="1">

                                        <!-- Кнопка перехода в режим редактирования -->
                                        <Button Classes="ControlButton SideButton GradientButton"
                                                Command="{Binding EditMarkerCommand}"
                                                Height="{Binding ButtonHeight1}"
                                                VerticalAlignment="Bottom"
                                                HorizontalAlignment="Center">

                                            <Button.Transitions>
                                                <Transitions>
                                                    <DoubleTransition Property="Height"
                                                                      Duration="0:0:0.25" />
                                                </Transitions>
                                            </Button.Transitions>

                                            <StackPanel Classes="StackButtonControl">

                                                <Image Source="/Assets/editIcon.png"
                                                       Height="20"
                                                       Width="20" />

                                                <TextBlock Text="Изменить"
                                                           Foreground="White"
                                                           FontWeight="Bold"
                                                           FontSize="12" />

                                            </StackPanel>

                                        </Button>

                                        <!-- Кнопка применения изменений -->
                                        <Button Classes="ControlButton SideButton GradientButton"
                                                Command="{Binding ApplyChangesCommand}"
                                                Height="{Binding ButtonHeight2}"
                                                VerticalAlignment="Top"
                                                HorizontalAlignment="Center">

                                            <Button.Transitions>
                                                <Transitions>
                                                    <DoubleTransition Property="Height"
                                                                      Duration="0:0:0.25" />
                                                </Transitions>
                                            </Button.Transitions>

                                            <StackPanel Classes="StackButtonControl">

                                                <Image Source="/Assets/ConfirmIcon.png"
                                                       Height="20"
                                                       Width="20" />

                                                <TextBlock Text="Применить"
                                                           Foreground="White"
                                                           FontWeight="Bold"
                                                           FontSize="12" />

                                            </StackPanel>

                                        </Button>

                                    </Grid>

                                    <!-- Кнопка отмены изменений -->
                                    <Button Grid.Column="2"
                                            Classes="ControlButton SideButton GradientButton"
                                            Command="{Binding CancelChangesCommand}"
                                            HorizontalAlignment="Right">

                                        <StackPanel Classes="StackButtonControl">

                                            <Image Source="/Assets/cross.png"
                                                   Height="20"
                                                   Width="20" />

                                            <TextBlock Text="Отмена"
                                                       Foreground="White"
                                                       FontWeight="Bold"
                                                       FontSize="12" />

                                        </StackPanel>

                                    </Button>

                                </Grid>

                            </Grid>

                        </Border>

                    </Grid>

                </Border>

                <!-- Контейнер карты -->
                <Border Grid.Column="1"
                        CornerRadius="11"
                        ClipToBounds="True">

                    <Grid>

                        <!-- Элемент управления картой Mapsui -->
                        <avalonia:MapControl x:Name="mapControl"
                                             ClipToBounds="True"
                                             Map="{Binding Map}"
                                             IsVisible="{Binding IsMapVisible}">

                        </avalonia:MapControl>

                        <!-- Нижняя правая панель с кнопками действий -->
                        <StackPanel HorizontalAlignment="Right"
                                    VerticalAlignment="Bottom"
                                    Orientation="Horizontal">

                            <Border Classes="Tile"
                                    Background="#F809030E"
                                    Width="{Binding PanelWidth2}"
                                    Margin="8">

                                <Border.Transitions>
                                    <Transitions>
                                        <DoubleTransition Property="Width"
                                                          Duration="0:0:0.3" />
                                    </Transitions>
                                </Border.Transitions>

                                <StackPanel Orientation="Vertical">

                                    <!-- Заголовок панели действий -->
                                    <Border HorizontalAlignment="Stretch"
                                            Margin="5">

                                        <TextBlock Text="Действия"
                                                   FontSize="18"
                                                   Foreground="White"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center" />

                                    </Border>

                                    <!-- Кнопка добавления новой метки -->
                                    <Button Classes="ControlButton SideButton GradientButton"
                                            Command="{Binding OpenListCommand}">

                                        <StackPanel Classes="StackButtonControl">

                                            <Image Source="/Assets/plus.png"
                                                   Height="20"
                                                   Width="20" />

                                            <TextBlock Text="Добавить"
                                                       Foreground="White"
                                                       FontWeight="Bold"
                                                       FontSize="18" />

                                        </StackPanel>

                                    </Button>

                                    <!-- Кнопка закрытия панели действий -->
                                    <Button Classes="ControlButton SideButton GradientButton"
                                            Command="{Binding ClosePanel2Command}">

                                        <StackPanel Classes="StackButtonControl">

                                            <Image Source="/Assets/cross.png"
                                                   Height="20"
                                                   Width="20" />

                                            <TextBlock Text="Отмена"
                                                       Foreground="White"
                                                       FontWeight="Bold"
                                                       FontSize="18" />

                                        </StackPanel>

                                    </Button>

                                </StackPanel>

                            </Border>

                        </StackPanel>

                        <!-- Затемнение фона при открытом списке изображений -->
                        <Border Background="#0e071f"
                                IsHitTestVisible="{Binding IsListOpen}"
                                Opacity="{Binding OverlayOpacity}"
                                PointerPressed="Overlay_PointerPressed">

                            <Border.Transitions>
                                <Transitions>
                                    <DoubleTransition Property="Opacity"
                                                      Duration="0:0:0.5" />
                                </Transitions>
                            </Border.Transitions>

                        </Border>

                        <!-- Модальное окно выбора/добавления изображений -->
                        <Border Classes="Tile"
                                Background="#F809030E"
                                ClipToBounds="True"
                                Width="{Binding BorderListWidth}"
                                Height="{Binding BorderListHeight}"
                                IsEnabled="{Binding IsListOpen}">

                            <Border.Transitions>
                                <Transitions>
                                    <DoubleTransition Property="Height"
                                                      Duration="0:0:0.2" />
                                    <DoubleTransition Property="Width"
                                                      Duration="0:0:0.2" />
                                </Transitions>
                            </Border.Transitions>

                            <Grid>

                                <!-- Фон модального окна -->
                                <Image Source="/Assets/BackGroung.png"
                                       Stretch="Fill" />

                                <!-- Затемнение фона модального окна -->
                                <Border Classes="Overlay" />

                                <!-- Основное содержимое модального окна -->
                                <Grid RowDefinitions="* Auto"
                                      IsVisible="{Binding IsListOpen}"
                                      Opacity="{Binding IconsOpacity}">

                                    <Grid.Transitions>
                                        <Transitions>
                                            <DoubleTransition Property="Opacity"
                                                              Duration="0:0:0.5">
                                            </DoubleTransition>
                                        </Transitions>
                                    </Grid.Transitions>

                                    <!-- Область с сеткой изображений -->
                                    <Border Grid.Row="0"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Stretch"
                                            Margin="10">

                                        <Border.OpacityMask>
                                            <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                                                <GradientStop Color="Transparent" Offset="0.0" />
                                                <GradientStop Color="White" Offset="0.15" />
                                                <GradientStop Color="White" Offset="0.85" />
                                                <GradientStop Color="Transparent" Offset="1.0" />
                                            </LinearGradientBrush>
                                        </Border.OpacityMask>

                                        <!-- Прокручиваемая сетка изображений -->
                                        <ScrollViewer HorizontalAlignment="Stretch"
                                                      VerticalAlignment="Stretch"
                                                      Margin="10">
                                            
                                            <ItemsControl ItemsSource="{Binding Images}"
                                                          HorizontalAlignment="Stretch"
                                                          VerticalAlignment="Stretch">

                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>

                                                <ItemsControl.ItemTemplate>
                                                    
                                                    <DataTemplate>
                                                        
                                                        <!-- Кнопка выбора изображения -->
                                                        <Button Classes="SideButton"
                                                                Command="{Binding $parent[Window].DataContext.SelectIconCommand}"
                                                                CommandParameter="{Binding}"
                                                                Padding="0"
                                                                Margin="5">
                                                            
                                                            <Border BorderThickness="5"
                                                                    CornerRadius="10"
                                                                    Classes="Tile"
                                                                    Padding="5"
                                                                    BorderBrush="{Binding IsSelected, Converter={StaticResource BoolToBrushConverter}}">

                                                                <Image Source="{Binding Image}"
                                                                       Width="64"
                                                                       Height="64" />
                                                                
                                                            </Border>
                                                            
                                                        </Button>
                                                        
                                                    </DataTemplate>
                                                    
                                                </ItemsControl.ItemTemplate>
                                                
                                            </ItemsControl>
                                            
                                        </ScrollViewer>
                                        
                                    </Border>

                                    <!-- Нижняя панель управления модального окна -->
                                    <Border Grid.Row="1"
                                            Classes="Tile"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Stretch"
                                            Margin="10">

                                        <Grid HorizontalAlignment="Stretch"
                                              ColumnDefinitions="Auto Auto *">

                                            <!-- Кнопка добавления метки (в режиме создания) -->
                                            <Button Grid.Column="0" Classes="ControlButton GradientButton SideButton"
                                                    Command="{Binding AddMarkerFromPendingCommand}"
                                                    IsVisible="{Binding !IsEditing}"
                                                    HorizontalAlignment="Left">

                                                <StackPanel Classes="StackButtonControl">

                                                    <Image Source="/Assets/plus.png"
                                                           Height="20"
                                                           Width="20" />

                                                    <TextBlock Text="Добавить"
                                                               Foreground="White"
                                                               FontWeight="Bold"
                                                               FontSize="18" />

                                                </StackPanel>

                                            </Button>

                                            <!-- Кнопка применения изменений изображения (в режиме редактирования) -->
                                            <Button Grid.Column="0" Classes="ControlButton GradientButton SideButton"
                                                    Command="{Binding ApplySelectedIconCommand}"
                                                    IsVisible="{Binding IsEditing}"
                                                    HorizontalAlignment="Left">

                                                <StackPanel Classes="StackButtonControl">

                                                    <Image Source="/Assets/ConfirmIcon.png"
                                                           Height="20"
                                                           Width="20" />

                                                    <TextBlock Text="Применить"
                                                               Foreground="White"
                                                               FontWeight="Bold"
                                                               FontSize="18" />

                                                </StackPanel>

                                            </Button>

                                            <!-- Кнопка закрытия модального окна -->
                                            <Button Grid.Column="1" Classes="ControlButton SideButton GradientButton"
                                                    Command="{Binding CloseListCommand}"
                                                    HorizontalAlignment="Left">

                                                <StackPanel Classes="StackButtonControl">

                                                    <Image Source="/Assets/cross.png"
                                                           Height="20"
                                                           Width="20" />

                                                    <TextBlock Text="Отмена"
                                                               Foreground="White"
                                                               FontWeight="Bold"
                                                               FontSize="18" />

                                                </StackPanel>

                                            </Button>

                                            <!-- Кнопка добавления своего изображения -->
                                            <Button Grid.Column="2" Classes="ControlButton SideButton GradientButton"
                                                    Command="{Binding AddOrEditIconCommand}"
                                                    HorizontalAlignment="Right">

                                                <StackPanel Classes="StackButtonControl">

                                                    <Image Source="/Assets/OpenFolderIcon.png"
                                                           Height="20"
                                                           Width="20" />

                                                    <TextBlock Text="Добавить свой"
                                                               Foreground="White"
                                                               FontWeight="Bold"
                                                               FontSize="18" />

                                                </StackPanel>

                                            </Button>

                                        </Grid>

                                    </Border>

                                </Grid>

                            </Grid>

                        </Border>

                        <!-- Рамка вокруг карты -->
                        <Border CornerRadius="10"
                                Margin="-2"
                                BorderBrush="#FF5500AA"
                                BorderThickness="6"/>

                    </Grid>

                </Border>

            </Grid>

        </Grid>

    </Grid>

</Window>